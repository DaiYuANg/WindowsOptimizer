<ui:FluentWindow
    x:Class="WindowsControlPanel.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:regions="http://prismlibrary.com/"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="MainWindow"
    Width="1180"
    Height="760"
    Background="Transparent"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    ExtendsContentIntoTitleBar="True"
    WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.Background>
            <StaticResource ResourceKey="GlassAmbientBrush" />
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="8,8,8,0"
                CornerRadius="10,10,0,0"
                Background="#26101924"
                BorderBrush="{StaticResource GlassStrokeBrush}"
                BorderThickness="1">
            <Grid Height="42" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <TextBlock FontSize="15" FontWeight="SemiBold" Text="Windows Optimizer" />
                    <TextBlock Margin="10,0,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="Control Panel" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <Button Width="34"
                            Height="28"
                            Margin="0,0,4,0"
                            Click="MinimizeButton_OnClick"
                            Content="-" />
                    <Button Width="34"
                            Height="28"
                            Margin="0,0,4,0"
                            Click="MaxRestoreButton_OnClick"
                            Content="□" />
                    <Button Width="34"
                            Height="28"
                            Click="CloseButton_OnClick"
                            Content="X" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="10"
                CornerRadius="12"
                Background="{StaticResource GlassShellBrush}"
                BorderBrush="{StaticResource GlassStrokeBrush}"
                BorderThickness="1">
            <ContentControl
                regions:RegionManager.RegionName="ContentRegion"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" />
        </Border>
    </Grid>
</ui:FluentWindow>
