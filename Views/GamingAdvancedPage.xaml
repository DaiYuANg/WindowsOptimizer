<UserControl x:Class="WindowsControlPanel.Views.GamingAdvancedPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mvvm="http://prismlibrary.com/"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mvvm:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="900">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="游戏高级工具" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="整合游戏相关深层设置，并提供一键性能模式。"
                       TextWrapping="Wrap" />
        </StackPanel>

        <ui:Card Grid.Row="1"
                 Margin="0,0,0,14"
                 Padding="14"
                 Background="{StaticResource GlassPanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="{Binding StatusSummary}" />
                <ui:Button Grid.Column="1"
                           Width="110"
                           Margin="12,0,0,0"
                           Appearance="Secondary"
                           Command="{Binding RefreshStatusCommand}"
                           Content="刷新状态" />
            </Grid>
        </ui:Card>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:Card Grid.Column="0" Margin="0,0,8,0" Padding="14">
                <StackPanel>
                    <TextBlock FontSize="17" FontWeight="SemiBold" Text="性能预设" />
                    <TextBlock Margin="0,6,0,10"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="执行游戏模式脚本，关闭虚拟化链路并偏向性能。"
                               TextWrapping="Wrap" />
                    <ui:Button Width="150"
                               Appearance="Danger"
                               Command="{Binding ApplyGamingModeCommand}"
                               Content="应用游戏模式" />
                </StackPanel>
            </ui:Card>

            <ui:Card Grid.Column="1" Margin="8,0,0,0" Padding="14">
                <StackPanel>
                    <TextBlock FontSize="17" FontWeight="SemiBold" Text="图形与游戏设置入口" />
                    <TextBlock Margin="0,6,0,10"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="快速进入 Windows 深层图形/游戏设置页面。"
                               TextWrapping="Wrap" />
                    <WrapPanel>
                        <ui:Button Width="170" Margin="0,0,8,8" Appearance="Secondary" Command="{Binding OpenGraphicsSettingsCommand}" Content="打开图形设置" />
                        <ui:Button Width="170" Margin="0,0,8,8" Appearance="Secondary" Command="{Binding OpenGameModeSettingsCommand}" Content="打开游戏模式设置" />
                    </WrapPanel>
                    <WrapPanel>
                        <ui:Button Width="170" Margin="0,0,8,8" Appearance="Secondary" Command="{Binding OpenGameBarSettingsCommand}" Content="打开游戏栏设置" />
                    </WrapPanel>
                </StackPanel>
            </ui:Card>
        </Grid>

        <ui:Card Grid.Row="3" Margin="0,14,0,0" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" FontSize="15" FontWeight="SemiBold" Text="执行日志" />
                <TextBox Grid.Row="1"
                         Margin="0,8,0,10"
                         Text="{Binding ExecutionLog, Mode=OneWay}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Width="110" Appearance="Secondary" Command="{Binding BackToHomeCommand}" Content="返回首页" />
                </StackPanel>
            </Grid>
        </ui:Card>
    </Grid>
</UserControl>
