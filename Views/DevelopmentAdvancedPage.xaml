<UserControl x:Class="WindowsControlPanel.Views.DevelopmentAdvancedPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mvvm="http://prismlibrary.com/"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mvvm:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="900">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="开发高级工具" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="封装开发者模式、Sudo、包清单导出等深层动作。"
                       TextWrapping="Wrap" />
        </StackPanel>

        <ui:Card Grid.Row="1"
                 Margin="0,0,0,14"
                 Padding="14"
                 Background="{StaticResource GlassPanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="{Binding StatusSummary}" />
                <ui:Button Grid.Column="1"
                           Width="110"
                           Margin="12,0,0,0"
                           Appearance="Secondary"
                           Command="{Binding RefreshStatusCommand}"
                           Content="刷新状态" />
            </Grid>
        </ui:Card>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:Card Grid.Column="0" Margin="0,0,8,0" Padding="14">
                <StackPanel>
                    <TextBlock FontSize="17" FontWeight="SemiBold" Text="开发系统能力" />
                    <TextBlock Margin="0,6,0,10"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="写注册表修改开发者模式，需要管理员权限。"
                               TextWrapping="Wrap" />
                    <WrapPanel>
                        <ui:Button Width="140" Margin="0,0,8,8" Appearance="Primary" Command="{Binding EnableDeveloperModeCommand}" Content="启用开发者模式" />
                        <ui:Button Width="140" Margin="0,0,8,8" Appearance="Secondary" Command="{Binding DisableDeveloperModeCommand}" Content="禁用开发者模式" />
                    </WrapPanel>
                    <WrapPanel>
                        <ui:Button Width="140" Margin="0,0,8,8" Appearance="Primary" Command="{Binding EnableSudoCommand}" Content="启用 Windows Sudo" />
                        <ui:Button Width="140" Margin="0,0,8,8" Appearance="Secondary" Command="{Binding DisableSudoCommand}" Content="禁用 Windows Sudo" />
                    </WrapPanel>
                </StackPanel>
            </ui:Card>

            <ui:Card Grid.Column="1" Margin="8,0,0,0" Padding="14">
                <StackPanel>
                    <TextBlock FontSize="17" FontWeight="SemiBold" Text="开发环境迁移" />
                    <TextBlock Margin="0,6,0,10"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="导出 winget 包清单，便于重装系统后恢复开发环境。"
                               TextWrapping="Wrap" />
                    <ui:Button Width="170"
                               Appearance="Secondary"
                               Command="{Binding ExportWingetCommand}"
                               Content="导出 winget 清单" />
                </StackPanel>
            </ui:Card>
        </Grid>

        <ui:Card Grid.Row="3" Margin="0,14,0,0" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" FontSize="15" FontWeight="SemiBold" Text="执行日志" />
                <TextBox Grid.Row="1"
                         Margin="0,8,0,10"
                         Text="{Binding ExecutionLog, Mode=OneWay}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Width="110" Appearance="Secondary" Command="{Binding BackToHomeCommand}" Content="返回首页" />
                </StackPanel>
            </Grid>
        </ui:Card>
    </Grid>
</UserControl>
